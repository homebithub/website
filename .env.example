# API Configuration
# Copy this file to .env and update with your values

# Gateway/API Base URL
# For local development: http://localhost:3005
# For production: https://api.homebit.co.ke
GATEWAY_API_BASE_URL=http://localhost:3005

# Frontend requests must go through the gateway. Do not point website env
# variables at auth, notifications, payments, or other backend service ports.

