# API Configuration
# Copy this file to .env and update with your values

# Gateway/API Base URL
# For local development: http://localhost:3005
# For production: https://preprod-api.homebit.co.ke
GATEWAY_API_BASE_URL=http://localhost:3005
AUTH_API_BASE_URL=http://localhost:5004

# Most frontend requests go through the gateway. Signup is proxied by the web
# server to homebit-auth's local raw gRPC endpoint while ListProfiles is pending.

# Google OAuth
GOOGLE_CLIENT_ID=562184165636-klkgj2b74194819lgh5netj4s2e343o2.apps.googleusercontent.com

# Optional profile catalogue ID overrides from homebit-auth profile.id.
# Signup falls back to the current HouseHelp/Household UUIDs until ListProfiles is available.
HOUSEHOLD_PROFILE_ID=
HOUSEHELP_PROFILE_ID=

# Node Environment
NODE_ENV=development
